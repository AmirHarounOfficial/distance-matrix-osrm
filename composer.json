{
    "name": "haroun/distance-matrix",
    "description": "A Laravel package for OSRM routing and distance matrix functionality.",
    "keywords": ["laravel", "osrm", "routing", "distance-matrix", "geolocation"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Haroun",
            "homepage": "https://github.com/AmirHarounOfficial"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.2"
    },
    "autoload": {
        "psr-4": {
            "Haroun\\DistanceMatrix\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Haroun\\DistanceMatrix\\DistanceMatrixServiceProvider"
            ],
            "aliases": {
                "DistanceMatrix": "Haroun\\DistanceMatrix\\DistanceMatrix"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
